{
  "name": "@alathar/platform",
  "private": true,
  "version": "0.1.0",
  "description": "Al-Athar Academy V2 monorepo (Next.js + NestJS)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @alathar/web",
    "dev:api": "npm run start:dev -w @alathar/api",
    "build:web": "npm run build -w @alathar/web",
    "build:api": "npm run build -w @alathar/api",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
}
