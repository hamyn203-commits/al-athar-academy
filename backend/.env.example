# Backend Environment Variables — Al-Athar Academy

PORT=5000
MONGODB_URI=mongodb://localhost:27017/alathar
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# AI (optional — falls back to local mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Amazon Bedrock (Claude via API key — optional)
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# Meetings
DEFAULT_MEETING_PROVIDER=jitsi
ZOOM_MEETING_BASE_URL=
GOOGLE_MEET_BASE_URL=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Al-Athar <noreply@alathar.edu>

# Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp / SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Push (FCM)
FCM_SERVER_KEY=

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
