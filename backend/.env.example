# Backend Environment Variables — Al-Athar Academy V4.3

PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/alathar

# URLs
FRONTEND_URL=https://al-athar-academy.vercel.app
SITE_URL=https://al-athar-academy.vercel.app
API_PUBLIC_URL=https://al-athar-api.azurewebsites.net
ALLOWED_ORIGINS=https://al-athar-academy.vercel.app,http://localhost:5173,http://localhost:5174

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI (optional — OpenAI → Bedrock → Gemini → local)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# Donations (optional payment links)
STRIPE_DONATION_URL=
PAYPAL_DONATION_URL=

# Meetings
DEFAULT_MEETING_PROVIDER=jitsi
ZOOM_MEETING_BASE_URL=
GOOGLE_MEET_BASE_URL=

# LiveKit (optional live sessions)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# Azure Storage (recordings)
AZURE_STORAGE_CONNECTION_STRING=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Al-Athar <noreply@alathar.edu>

# Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp / SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Push (FCM)
FCM_SERVER_KEY=
